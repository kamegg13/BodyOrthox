<?xml version="1.0" encoding="utf-8"?>
<!-- Famille Source Sans 3 (corps de texte) : voir lexend.xml pour la raison
     du montage res/font + fontVariationSettings par graisse. -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        app:font="@font/sourcesans3_wght"
        app:fontStyle="normal"
        app:fontWeight="400"
        app:fontVariationSettings="'wght' 400" />
    <font
        app:font="@font/sourcesans3_wght"
        app:fontStyle="normal"
        app:fontWeight="500"
        app:fontVariationSettings="'wght' 500" />
    <font
        app:font="@font/sourcesans3_wght"
        app:fontStyle="normal"
        app:fontWeight="600"
        app:fontVariationSettings="'wght' 600" />
    <font
        app:font="@font/sourcesans3_wght"
        app:fontStyle="normal"
        app:fontWeight="700"
        app:fontVariationSettings="'wght' 700" />
</font-family>
