# iOS 16+ requis — Impeller stable, ML Kit performant (NFR-P2, architecture.md)
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Note: les configurations Debug-dev/Release-dev/Debug-prod/Release-prod seront
# ajoutées au Podfile uniquement après avoir créé les schemes Flutter correspondants
# dans Xcode (via flutter build --flavor). Pour l'instant, seules les 3 configs
# par défaut existent dans Runner.xcodeproj.
project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  # SQLCipher AES-256 — chiffrement base de données (Story 1-3)
  # CRITIQUE : sans ce pod, NativeDatabase.createInBackground ignore PRAGMA key
  # et ouvre une SQLite standard non chiffrée, sans erreur visible.
  pod 'SQLCipher', '~> 4.5'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['SWIFT_VERSION'] = '5.0'

      # Fix iOS 26 + Apple Silicon simulator — ML Kit static archive platform mismatch
      #
      # Root cause : ML Kit fat binaries = arm64-device + x86_64-simulator.
      # iOS 26 a supprimé Rosetta → x86_64 mort. arm64 slice tagué "iOS" (device)
      # → linker refuse de le lier dans un binary iOS-simulator.
      #
      # Solution : exclure les .m files référençant des symboles ML Kit pour simulateur.
      # Le static linker n'extrait aucun object file ML Kit → pas d'erreur de platform.
      # Runner/GoogleMlKitSimulatorStubs.m fournit les stubs de channel pour simulateur.
      if target.name == 'google_mlkit_pose_detection'
        config.build_settings['EXCLUDED_SOURCE_FILE_NAMES[sdk=iphonesimulator*]'] = 'GoogleMlKitPoseDetectionPlugin.m'
      elsif target.name == 'google_mlkit_commons'
        config.build_settings['EXCLUDED_SOURCE_FILE_NAMES[sdk=iphonesimulator*]'] = 'MLKVisionImage+FlutterPlugin.m GenericModelManager.m'
      end
    end
  end

  # Patch xcconfig 1 : retirer arm64 de EXCLUDED_ARCHS simulateur
  # (nécessaire pour autoriser le build arm64 simulateur)
  Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig_path|
    content = File.read(xcconfig_path)
    modified = content.gsub(
      /^EXCLUDED_ARCHS\[sdk=iphonesimulator\*\] = arm64$/,
      'EXCLUDED_ARCHS[sdk=iphonesimulator*] = i386'
    )
    File.write(xcconfig_path, modified) if modified != content
  end

  # Patch xcconfig 2 : retirer les frameworks ML Kit de OTHER_LDFLAGS pour simulateur
  #
  # Root cause finale : le flag -ObjC dans OTHER_LDFLAGS force le linker à charger
  # TOUS les object files ObjC de TOUTES les static archives liées, dont MLImage.
  # MLImage.framework est une static archive arm64-device → erreur platform mismatch.
  #
  # Solution : créer OTHER_LDFLAGS[sdk=iphonesimulator*] sans les 7 frameworks ML Kit.
  # GoogleMlKitSimulatorStubs.m (Runner) fournit les stubs de channel à la place.
  ml_frameworks = %w[MLImage MLKitCommon MLKitVision MLKitPoseDetection MLKitPoseDetectionAccurate MLKitPoseDetectionCommon MLKitXenoCommon]

  Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Runner', '*.xcconfig')).each do |xcconfig_path|
    content = File.read(xcconfig_path)
    next unless content.include?('OTHER_LDFLAGS = $(inherited)')
    next if content.include?('OTHER_LDFLAGS[sdk=iphonesimulator*]')

    match = content.match(/^OTHER_LDFLAGS = (.+)$/)
    next unless match

    sim_flags = match[1].dup
    ml_frameworks.each { |fw| sim_flags.gsub!(/ -framework "#{fw}"/, '') }

    content += "OTHER_LDFLAGS[sdk=iphonesimulator*] = #{sim_flags}\n"
    File.write(xcconfig_path, content)
  end
end
